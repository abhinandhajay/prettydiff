{
    "name": "@abhinandhajay/prettydiff",
    "version": "0.2.0",
    "description": "Open the working-tree diff of any git repo in a local web viewer.",
    "keywords": [
        "cli",
        "diff",
        "git",
        "viewer"
    ],
    "homepage": "https://github.com/abhinandhajay/prettydiff#readme",
    "bugs": {
        "url": "https://github.com/abhinandhajay/prettydiff/issues"
    },
    "license": "MIT",
    "author": "Abhinandh Ajay",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/abhinandhajay/prettydiff.git"
    },
    "bin": {
        "prettydiff": "dist/cli/bin.js"
    },
    "files": [
        "dist/cli",
        "dist/web",
        "CHANGELOG.md"
    ],
    "type": "module",
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "dev": "vite",
        "build:web": "vite build",
        "build:cli": "tsc -p tsconfig.cli.json && chmod +x dist/cli/bin.js",
        "build": "bun run build:web && bun run build:cli",
        "prepublishOnly": "bun run build",
        "start": "node dist/cli/bin.js",
        "test": "bun test",
        "lint": "oxlint .",
        "lint:fix": "oxlint --fix .",
        "format": "oxfmt --write .",
        "format:check": "oxfmt --check ."
    },
    "dependencies": {
        "@hono/node-server": "^2.0.2",
        "@pierre/diffs": "^1.1.21",
        "@pierre/trees": "^1.0.0-beta.3",
        "get-port": "^7.2.0",
        "hono": "^4.12.18",
        "mri": "^1.2.0",
        "open": "^11.0.0",
        "parse-diff": "^0.12.0",
        "radix-ui": "^1.4.3",
        "react": "^19.2.6",
        "react-dom": "^19.2.6"
    },
    "devDependencies": {
        "@radix-ui/react-collapsible": "^1.1.12",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-toggle": "^1.1.10",
        "@radix-ui/react-toggle-group": "^1.1.11",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@tailwindcss/vite": "^4.3.0",
        "@types/bun": "^1.3.14",
        "@types/node": "^25.6.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^1.14.0",
        "oxfmt": "0.42.0",
        "oxlint": "1.57.0",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4",
        "tw-animate-css": "^1.4.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.11"
    },
    "engines": {
        "node": ">=18.17"
    }
}
