{
    "name": "@abhinandhajay/prettydiff",
    "version": "0.6.0",
    "description": "Open the working-tree diff of any git repo in a local web viewer.",
    "keywords": [
        "cli",
        "diff",
        "git",
        "viewer"
    ],
    "homepage": "https://github.com/abhinandhajay/prettydiff#readme",
    "bugs": {
        "url": "https://github.com/abhinandhajay/prettydiff/issues"
    },
    "license": "MIT",
    "author": "Abhinandh Ajay",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/abhinandhajay/prettydiff.git"
    },
    "bin": {
        "prettydiff": "dist/cli/bin.js"
    },
    "files": [
        "dist/cli",
        "dist/web",
        "CHANGELOG.md"
    ],
    "type": "module",
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "dev": "vite",
        "build:web": "vite build",
        "build:cli": "tsc -p tsconfig.cli.json && chmod +x dist/cli/bin.js",
        "build": "bun run build:web && bun run build:cli",
        "prepublishOnly": "bun run build",
        "start": "node dist/cli/bin.js",
        "test": "bun test",
        "lint": "oxlint .",
        "lint:fix": "oxlint --fix .",
        "format": "oxfmt --write .",
        "format:check": "oxfmt --check ."
    },
    "dependencies": {
        "@hono/node-server": "^2.0.6",
        "@pierre/diffs": "^1.2.12",
        "@pierre/trees": "^1.0.0-beta.5",
        "@radix-ui/react-select": "^2.3.2",
        "get-port": "^7.2.0",
        "hono": "^4.12.27",
        "mri": "^1.2.0",
        "open": "^11.0.0",
        "parse-diff": "^0.12.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-resizable-panels": "^4.12.0"
    },
    "devDependencies": {
        "@happy-dom/global-registrator": "^20.10.6",
        "@radix-ui/react-checkbox": "^1.3.6",
        "@radix-ui/react-collapsible": "^1.1.15",
        "@radix-ui/react-scroll-area": "^1.2.13",
        "@radix-ui/react-separator": "^1.1.11",
        "@radix-ui/react-slot": "^1.3.0",
        "@radix-ui/react-toggle": "^1.1.13",
        "@radix-ui/react-toggle-group": "^1.1.14",
        "@tailwindcss/vite": "^4.3.2",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/bun": "^1.3.14",
        "@types/node": "^26.1.0",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "happy-dom": "^20.10.6",
        "lucide-react": "^1.23.0",
        "oxfmt": "0.57.0",
        "oxlint": "1.72.0",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.2",
        "tw-animate-css": "^1.4.0",
        "typescript": "^6.0.3",
        "vite": "^8.1.2"
    },
    "engines": {
        "node": ">=18.17"
    }
}
