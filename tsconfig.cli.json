{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "outDir": "dist/cli",
        "rootDir": "src/cli",
        "declaration": false,
        "types": ["node"]
    },
    "include": ["src/cli/**/*.ts"],
    "exclude": ["node_modules", "dist", "src/web", "src/cli/**/*.test.ts", "src/cli/testUtils.ts"]
}
